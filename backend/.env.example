# ---------------------------------------------------------
# PlaceMentor AI - Environment Variables
# ---------------------------------------------------------

# Get a FREE Groq API key at: https://console.groq.com/keys
GROQ_API_KEY=your_groq_api_key_here

# Free model on Groq (fast + no cost on free tier)
GROQ_MODEL=llama-3.3-70b-versatile

# Server port
PORT=8080

# JWT secret for auth (generate any random string)
JWT_SECRET=change_this_to_a_random_secret_string

# Optional: MongoDB Atlas free-tier connection string.
# If left empty, the app uses a local file-based database (db.json)
# so it runs completely free with zero external signup required.
MONGODB_URI=

# ---------------------------------------------------------
# Admin account (this is YOUR login, separate from members)
# ---------------------------------------------------------
# Set these once, restart the server, and this account is auto-created
# with role "admin". Log in with these on the same /login page members use -
# the app detects the role and sends you to the Admin Dashboard instead.
ADMIN_EMAIL=admin@placementor.ai
ADMIN_PASSWORD=change_this_to_a_strong_password
